#!/usr/bin/env bash
# synrun <env> <cmd...> — containerless port of docker/synrun.
#   Run a command inside a tool's isolated micromamba env, with the script-only
#   repos placed on PYTHONPATH and all caches pointed at the right (shared/per-user)
#   locations. Same contract as the in-image launcher — callers don't change.
#
#   synrun proteinmpnn python /…/ProteinMPNN/protein_mpnn_run.py --help
#   synrun esm         python -c "import esm; print(esm.__version__)"
#   synrun dnatools    python -c "import dnachisel, RNA, Bio; print('ok')"
#   synrun spurs       bash      # interactive shell in the spurs env
set -euo pipefail

# Sets SYNBIO_ROOT, MAMBA_ROOT_PREFIX, caches, and puts micromamba on PATH.
# (synrun lives at $REPO/env/bin/synrun, so synenv.sh is one dir up.)
# shellcheck source=/dev/null
source "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/synenv.sh"

env_name="${1:?usage: synrun <env> <cmd...>}"; shift || true

# Repos without an installable package need to be importable via PYTHONPATH.
case "$env_name" in
  proteinmpnn) repo_pp="$SYNBIO_ROOT/docker/repos/ProteinMPNN" ;;
  ligandmpnn)  repo_pp="$SYNBIO_ROOT/docker/repos/LigandMPNN" ;;
  thermompnn)  repo_pp="$SYNBIO_ROOT/docker/repos/ThermoMPNN-D:$SYNBIO_ROOT/docker/repos/ThermoMPNN-D/proteinmpnn" ;;
  *)           repo_pp="" ;;
esac

new_pp="${repo_pp}"
[ -n "${PYTHONPATH:-}" ] && new_pp="${new_pp:+$new_pp:}${PYTHONPATH}"

if [ "$#" -eq 0 ]; then set -- bash; fi
exec micromamba run -n "$env_name" env PYTHONPATH="$new_pp" "$@"
